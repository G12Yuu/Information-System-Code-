pred_binary <- ifelse(pred_test == "None", 0, 1) 
true_binary <- ifelse(y_test == "None", 0, 1)

sex_group <- test_data$Sex 

fairness_df <- data.frame(
  Sex = sex_group,
  Pred = pred_binary,
  True = true_binary
)
 
  fairness_df$SexLabel <- ifelse(fairness_df$Sex == 1, "Male", "Female")

demographic_parity <- fairness_df %>%
    group_by(SexLabel) %>% summarise (
      Positive_Prediction_Rate = mean (Pred == 1))

demographic_parity


equal_opportunity <- fairness_df %>%
  filter (True == 1) %>% 
  group_by (SexLabel) %>%
  summarise (
    True_Positive_Rate = mean (Pred == 1)
  )

equal_opportunity

predictive_parity <- fairness_df %>%
  filter (Pred == 1) %>% 
  group_by (SexLabel) %>% 
  summarise(Precision = mean (True == 1))

predictive_parity

male_rate <- fairness_df %>% 
  filter(SexLabel == "Male") %>%
  summarise (rate = mean (Pred == 1)) %>%
  pull(rate)

female_rate <- fairness_df %>%
  filter(SexLabel == "Female") %>%
  summarise (rate = mean (Pred == 1)) %>%
  pull(rate)
disparate_impact <- female_rate / male_rate
disparate_impact

fairness_summary <- data.frame(
  Metric = c(
    "Demographic Parity - Male",
    "Demographic Parity - Female",
    "Equal Opportunity - Male",
    "Equal Opportunity - Female",
    "Predictive Parity - Male",
    "Predictive Parity - Female",
    "Disparate Impact (Female / Male)" 
),
    Value = c(
      demographic_parity$Positive_Prediction_Rate[demographic_parity$SexLabel == "Male"],
      demographic_parity$Positive_Prediction_Rate[demographic_parity$SexLabel == "Female"],
      equal_opportunity$True_Positive_Rate[equal_opportunity$SexLabel == "Male"],
      equal_opportunity$True_Positive_Rate[equal_opportunity$SexLabel == "Female"],
      predictive_parity$Precision[predictive_parity$SexLabel == "Male"], 
      predictive_parity$Precision[predictive_parity$SexLabel == "Female"], 
      disparate_impact
    )
)
fairness_summary
