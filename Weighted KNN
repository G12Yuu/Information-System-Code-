library(dplyr)
library(caret)

athletes <- read.csv("athlete_events.csv", stringsAsFactors = FALSE)
regions <- read.csv("noc_regions.csv", stringsAsFactors = FALSE)

winter_data <- athletes %>%
  filter(Season == "Winter",
         Year >= 1992,
         Year <= 2014) %>%
  select(Sex, Age, Height, Weight, Year, Sport, Medal)

winter_data

winter_data$Medal[is.na(winter_data$Medal)] <- "None"

winter_data <- winter_data %>%
  filter(!is.na(Age),
         !is.na(Height),
         !is.na(Weight))

winter_data$Sex <- ifelse(winter_data$Sex == "M", 1, 0)

winter_data$Medal <- factor(winter_data$Medal,
                            levels = c("None","Bronze","Silver","Gold"))
sport_dummies <- model.matrix(~ Sport - 1, data = winter_data)

winter_data <- cbind(winter_data[,c("Sex","Age","Height","Weight","Year","Medal")],
                     sport_dummies)

train_data <- winter_data %>% filter(Year >= 1992 & Year <= 2006)
valid_data <- winter_data %>% filter(Year == 2010)
test_data  <- winter_data %>% filter(Year == 2014)

X_train <- train_data %>% select(-Medal)
X_valid <- valid_data %>% select(-Medal)
X_test  <- test_data %>% select(-Medal)

y_train <- train_data$Medal
y_valid <- valid_data$Medal
y_test  <- test_data$Medal

train_means <- sapply(X_train, mean)
train_sds <- sapply(X_train, sd)

train_sds[train_sds == 0] <- 1

scale_data <- function(df, means, sds){
  df <- sweep(df, 2, means, "-")
  df <- sweep(df, 2, sds, "/")
  return(df)
}

X_train <- scale_data(X_train, train_means, train_sds)
X_valid <- scale_data(X_valid, train_means, train_sds)
X_test  <- scale_data(X_test, train_means, train_sds)

weighted_knn <- function(train_X, train_y, test_X, k = 5, p = 2){
  train_X <- as.matrix(train_X)
  test_X <- as.matrix(test_X)
  
  preds <- c()
  
  for(i in 1:nrow(test_X)){
    
    dists <- apply(train_X,1,function(row){
      sum(abs(row - test_X[i,])^p)^(1/p)
    })
    
    idx <- order(dists)[1:k]
    
    nn_labels <- train_y[idx]
    nn_dists <- dists[idx]
    
    weights <- 1/(nn_dists + 1e-8)
    
    vote <- tapply(weights, nn_labels, sum)
    
    pred <- names(vote)[which.max(vote)]
    
    preds <- c(preds, pred)
  }
  
  return(factor(preds, levels=levels(train_y)))
}


k_values <- c(3,5,7,9,11,15)

results <- data.frame()

for(k in k_values){
  
  cat("Running k =", k, "\n")
  
  pred <- weighted_knn(X_train, y_train, X_valid, k=k, p=2)
  
  cm <- confusionMatrix(pred, y_valid)
  
  results <- rbind(results,
                   data.frame(k=k,
                              Accuracy=cm$overall["Accuracy"]))
}

results

best_k <- results$k[which.max(results$Accuracy)]
best_k
 
pred_test <- weighted_knn(X_train, y_train, X_test, k = best_k, p = 2)

cm_test <- confusionMatrix(pred_test, y_test)
cm_test

accuracy <- cm_test$overall["Accuracy"]
accuracy

precision <- cm_test$byClass[, "Precision"]
recall <- cm_test$byClass[, "Recall"]
f1 <- cm_test$byClass[, "F1"]

precision
recall
f1

final_results <- data.frame(
  Metric = c("Accuracy"),
  Value = c(as.numeric(accuracy))
)

final_results

class_metrics <- data.frame(
