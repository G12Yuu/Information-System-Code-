# Decision Tree to predict medal type for the actual winners

library(nnet)
library(rpart)

actual_winners <- winter_data[winter_data$Medal != "None", ]
table(actual_winners$Medal)

actual_winners_2010 <- actual_winners[actual_winners$Year
                                      ==2010, ]
table(actual_winners_2010$Medal)

actual_winners_2014 <- actual_winners[actual_winners$Year
                                      ==2014, ]
table(actual_winners_2014$Medal)


# Decision tree

winners_val_set <- winter_data[winter_data$Year == 2010 &
                                 winter_data$Medal != "None", ]
table(winners_val_set$Medal)

winners_test_set <- winter_data[winter_data$Year == 2014 &
                                  winter_data$Medal != "None", ]
table(winners_test_set$Medal)

decision_tree <- rpart(Medal ~ Sex + Age + Height + Weight
                      + Sport + Year, 
                      data = actual_winners, 
                      method = "class", 
                      control = rpart.control(cp =0.0035))
# Choosing complexity value of 0.005 to see silver/gold/bronze

medal_colours <- c("Bronze" = "brown", "Gold" = "gold", "Silver" = "grey")
rpart.plot(decision_tree, box.col=medal_colours[decision_tree$frame$yval])

# Check variable importance
decision_tree$variable.importance
# Height is most important, year is least

# Evaluate performance

# Predict medal type using validation.test
tree_val <- predict(decision_tree, newdata = winners_val_set, 
                    type = "class")
winner_conf_val <- table(Predicted = tree_val, Actual = actual_winners_2010$Medal)
winner_conf_val

tree_test <- predict(decision_tree, newdata = winners_test_set, 
                     type = "class")
winner_conf_test <- table(Predicted = tree_test, Actual = actual_winners_2014$Medal)
winner_conf_test






