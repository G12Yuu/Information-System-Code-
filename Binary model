# Cleaning Data for model

data <- read.csv("athlete_events.csv")
data_2 <- data[data$Season == "Winter",]
data_3 <- data_2[data_2$Year >= 1990,]

# Picking only important variables
winter_data <- data_3[, c("Sex", "Age", "Height", 
                          "Weight", "Year", "Sport",
                          "Medal")]
rownames(winter_data) <- 1:nrow(winter_data)
nrow(winter_data)

# Fixing missing NA values
winter_data$Medal[is.na(winter_data$Medal)] <- "None"
colSums(is.na(winter_data))
winter_data <- winter_data[complete.cases(winter_data), ]

# Exploratory Analysis

summary(winter_data)

# Distribution of characteristics
par(mfrow=c(1, 3))
hist(winter_data$Age, xlab="Age", main="Age Distribution", col = "coral4")
hist(winter_data$Height, xlab = "Height", main ="Height Distribution", col = "coral3")
hist(winter_data$Weight, xlab="Weight", main="Weight Distribution", col = "coral2")

# Table of medal counts
table(winter_data$Medal)
barplot(table(winter_data$Medal), col=c("brown", "gold", "black", "gray"), #
        main="Class Imbalance")
table(winter_data$Sex, winter_data$Medal)
table(winter_data$Sport, winter_data$Medal)

# Medals vs Features
par(mfrow=c(1, 3))
boxplot(Age ~ Medal, winter_data, main="Medals vs Age", col = "burlywood4")
boxplot(Height ~ Medal, winter_data, main = "Medals vs Height", col = "burlywood3")
boxplot(Weight ~ Medal, winter_data, main="Medals vs Weight", col = "burlywood2")

# Correlation
library(corrplot)
matrix <- cor(winter_data[, 1:6])
corrplot(matrix)

# Entropy of medal distributions
probability_medal <- prop.table(table(winter_data$Medal))
probability_medal
