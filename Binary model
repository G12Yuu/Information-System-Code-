# Changing into binary variables for KNN

winter_data$Sex <- ifelse(winter_data$Sex == "M", 1, 0)
winter_data$Sport <- as.numeric(as.factor(winter_data$Sport))

# Set Target Variable for Binary

binary_class <- as.factor(ifelse(winter_data$Medal == "None", "No", "Yes"))

# Split into training, test, validation

training_set <- winter_data[winter_data$Year >= 1992 & 
                              winter_data$Year <= 2006, 
                            c("Sex", "Age", "Height", "Weight", "Year", "Sport")]
validation_set <- winter_data[winter_data$Year == 2010, c("Sex", "Age", "Height", 
                                                          "Weight", "Year", "Sport")]
testing_set <- winter_data[winter_data$Year == 2014, c("Sex", "Age", "Height", 
                                                      "Weight", "Year", "Sport")]

# Create separate dataframe for the real classifications

training_class <- binary_class[winter_data$Year >= 1992 & 
                                 winter_data$Year <= 2006]
validation_class <- binary_class[winter_data$Year == 2010]
testing_class <- binary_class[winter_data$Year == 2014]

# Scale dataset using training mean and sd

scaled_training <- scale(training_set)
mean <- attr(scaled_training, "scaled:center")
sd <- attr(scaled_training, "scaled:scale")       

scaled_validation <- scale(validation_set, center = mean, scale = sd)
scaled_testing <- scale(testing_set, center = mean, scale = sd)

# Use mean and sd to avoid data leakage

# Binary KNN

library(class)
library(pROC)
library(caret)

# Choose k

# Accuracy Graph

library(ggplot2)
k_values <- c(1, 3, 5, 7, 15, 19, 25, 35, 45, 50, 60, 70, 80, 90)
accuracy_values <- sapply(k_values, function(k) {
  classifier_knn <- knn(train = scaled_training,
                        test = scaled_testing,
                        cl = training_class,
                        k=k)
  1-mean(classifier_knn != training_class)
})

accuracy_data <- data.frame(K = k_values, Accuracy = accuracy_values)

ggplot(accuracy_data, aes(x=K, y=Accuracy)) + 
  geom_line(color="lightblue", size = 1) +
  geom_point(color = "lightgreen", size = 3) + 
  labs(title = "Model Accuracy for Different K Values", 
       x = "Number of Neighbours (K)", 
       y="Accuracy") + theme_minimal()

# Elbow Plot 

k_range <- 1:50
error <- numeric(length(k_range))
for(i in k_range)
{
  pred <- knn(scaled_training, scaled_validation, 
              training_class, i)
  error[i] <- 1-mean(pred == validation_class)
}

plot(k_range, error, type="b", pch=19, col="orangered", xlab="K Values", ylab="Error", 
     main="Elbow Plot for Optimal K")

## Valid > 30

# Run on validation
pred_validation <- knn(scaled_training, 
                       scaled_validation, 
                       training_class, 11)
# Confusion Matrix
conf_validation <- table(Predicted = pred_validation, Actual = validation_class)
conf_validation

# accuracy, precision, recall, f1 score
accuracy_val <- (conf_validation["Yes", "Yes"] + conf_validation["No", "No"]) / 
  sum(conf_validation)
accuracy_val

precision_val <- conf_validation["Yes", "Yes"] / (conf_validation["Yes", "Yes"]
                                                  + conf_validation["Yes", "No"])
precision_val

recall_val <- conf_validation["Yes", "Yes"] / (conf_validation["Yes", "Yes"] + 
                                                 conf_validation["No", "Yes"])
recall_val

f1_val <- 2 * (precision_val * recall_val) / (precision_val + recall_val)
f1_val


