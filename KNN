library(kknn)

train_knn <- winter[winter$Year <= 2006, ]
validation_knn <- winter[winter$Year == 2010, ]

train_knn$Medal <- as.factor(train_knn$Medal)
validation_knn$Medal <- as.factor(validation_knn$Medal)

knn_manhattan <- kknn(
  Medal ~ .,
  train = train_knn,
  test = validation_knn,
  k = best_k,
  distance = 1
)
pred_manhattan <- fitted(knn_manhattan)

mean(pred_manhattan == validation_knn$Medal)


